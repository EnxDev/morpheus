# ── LLM Provider ─────────────────────────────────────────────────────────────
# Auto-detected from available API keys: OPENAI_API_KEY → openai, ANTHROPIC_API_KEY → anthropic
# Falls back to ollama (local) if no key is set.
# Override with: MORPHEUS_LLM_PROVIDER=openai | anthropic | ollama
# MORPHEUS_LLM_PROVIDER=openai

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# ── Anthropic ────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_MAX_TOKENS=1024

# ── Ollama (local — no API key needed) ──────────────────────────────────────
# Used automatically when no remote API key is set.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=mistral

# ── Audit ────────────────────────────────────────────────────────────────────
# MORPHEUS_AUDIT_FILE=/var/log/morpheus/audit.jsonl

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_MOCK_DATA=true
